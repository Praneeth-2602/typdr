# ─────────────────────────────────────────────────────────────────────────────
# SwiftKeys — Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth (next-auth v4) ───────────────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -base64 32
# next-auth v4 reads NEXTAUTH_SECRET (not AUTH_SECRET which is Auth.js v5).
NEXTAUTH_SECRET=

# The canonical URL of your deployment. Required for redirects & CSRF checks.
# Locally: http://localhost:3000
# Vercel: https://your-app.vercel.app  (Vercel sets this automatically)
NEXTAUTH_URL=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Free tier available at https://cloud.mongodb.com
# Example: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Optional — database name. Defaults to "swiftkeys"
MONGODB_DB=swiftkeys

# ── AI Drill Generation (at least one required for AI drills) ─────────────────
# Groq  — free tier: 6 000 req/day, ~500 K tokens/day  → https://console.groq.com
GROQ_API_KEY=

# Gemini — free tier: 15 req/min, 1 M tokens/day        → https://aistudio.google.com
GEMINI_API_KEY=

# Optional provider preference for drill generation:
# auto (default) | groq | gemini
DRILL_PROVIDER=auto

# ── Phase 2: Background Job Queue (optional) ──────────────────────────────────
# If UPSTASH_URL + UPSTASH_TOKEN are set, jobs are pushed to Upstash Redis and
# can be consumed by a separate worker process.
# If unset, jobs run in-process (async, fire-and-forget) — works out of the box.
# Free tier at https://console.upstash.com — no credit card required.
UPSTASH_URL=
UPSTASH_TOKEN=
